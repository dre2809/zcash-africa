# ============================================================
# Zcash Africa — Environment Variables
# Copy to `.env.local` for local development. Set the same keys
# (with production values) in Vercel → Project → Settings → Environment Variables.
# ============================================================

# ── Database (PostgreSQL, e.g. Vercel Postgres / Neon / Supabase) ──
# Pooled connection used by the app at runtime
DATABASE_URL="postgresql://user:password@host:5432/zcash_africa?pgbouncer=true&connection_limit=1"
# Direct (non-pooled) connection used by Prisma Migrate
DIRECT_URL="postgresql://user:password@host:5432/zcash_africa"

# ── Auth.js / NextAuth ──
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-32-byte-random-string"
NEXTAUTH_URL="http://localhost:3000"

# OAuth providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ── Cloudinary ──
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# ── Sanity CMS ──
NEXT_PUBLIC_SANITY_PROJECT_ID=""
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2025-01-01"
SANITY_API_READ_TOKEN=""
SANITY_API_WRITE_TOKEN=""
SANITY_REVALIDATE_SECRET="replace-with-random-string"

# ── Newsletter (future-proofing — pluggable provider) ──
NEWSLETTER_PROVIDER="resend"
RESEND_API_KEY=""
NEWSLETTER_AUDIENCE_ID=""

# ── Misc ──
# Public site URL used for canonical links, sitemaps, and OAuth callbacks
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Comma-separated list of locales for i18n future-proofing
NEXT_PUBLIC_SUPPORTED_LOCALES="en,fr,sw"
